generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  items     Json
  status    String   @default("pending")
  total     Float
  createdAt DateTime @default(now())
}
